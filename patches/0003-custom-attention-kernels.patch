# Hooks GIPFEL custom attention kernels into both Megatron attention paths.
#
# WHAT:
#   When env var GIPFEL_ATTN_KERNEL is "triton" or "tilelang", both
#   DotProductAttention (used with --transformer-impl local) and
#   TEDotProductAttention (used with --transformer-impl transformer_engine)
#   short-circuit to a custom kernel via the gipfelsturm `kernels` package.
#   This lets us A/B the Triton/TileLang attention against native TE
#   attention (FA2/FA3/cuDNN) while keeping LayerNorm, sequence-parallel,
#   fused softmax etc. constant.
#
# WHERE:
#   1. Megatron-LM/megatron/core/transformer/dot_product_attention.py
#      DotProductAttention.forward — local path.
#   2. Megatron-LM/megatron/core/extensions/transformer_engine.py
#      TEDotProductAttention.forward — TE path. Patch inserts right after
#      the """Forward.""" docstring line and before the packed_seq_params
#      logic.
#
# WHY:
#   The TE-wrapper patch is the apples-to-apples comparison point: the rest
#   of the model (LN, MLP, fused softmax) is identical to the FA2/FA3/cuDNN
#   runs; only the attention kernel changes.
#
# HOW TO RELOCATE if line numbers shift:
#   - For the DotProductAttention patch, find "assert attention_bias is None"
#     in dot_product_attention.py and insert the new branch after it.
#   - For the TEDotProductAttention patch, find the docstring `"""Forward."""`
#     inside the forward() method of `class TEDotProductAttention(te.pytorch.DotProductAttention)`
#     and insert the new branch immediately after.

diff --git a/megatron/core/transformer/dot_product_attention.py b/megatron/core/transformer/dot_product_attention.py
index 69039e0bf..d2d3e92d0 100644
--- a/megatron/core/transformer/dot_product_attention.py
+++ b/megatron/core/transformer/dot_product_attention.py
@@ -2,6 +2,7 @@


 import math
+import os
 from typing import Optional, Tuple

 import torch
@@ -156,6 +157,24 @@ class DotProductAttention(MegatronModule):
         )
         assert attention_bias is None, "Attention bias is not supported for DotProductAttention."

+        # === GIPFEL custom kernel short-circuit ===
+        # When GIPFEL_ATTN_KERNEL is set, dispatch Q/K/V to a custom Triton or TileLang
+        # kernel via the gipfelsturm `kernels` package and return early. The kernel
+        # handles its own causal mask (taken from attn_mask_type) and GQA expansion.
+        _gipfel_kernel = os.environ.get("GIPFEL_ATTN_KERNEL", "").lower()
+        if _gipfel_kernel in ("triton", "tilelang"):
+            try:
+                from kernels import run_attention as _gipfel_run_attention
+            except ImportError as e:
+                raise RuntimeError(
+                    "GIPFEL_ATTN_KERNEL set but `kernels` package not importable; "
+                    "ensure $WORKDIR is on PYTHONPATH (launch-mp.sh should handle this)."
+                ) from e
+            _causal = (attn_mask_type == AttnMaskType.causal) if attn_mask_type is not None else True
+            _out = _gipfel_run_attention(query, key, value, _causal, self.softmax_scale)
+            sq_, b_, np_, hn_ = _out.shape
+            return _out.reshape(sq_, b_, np_ * hn_)
+
         # ===================================
         # Raw attention scores. [b, n/p, s, s]
         # ===================================
diff --git a/megatron/core/extensions/transformer_engine.py b/megatron/core/extensions/transformer_engine.py
index ef8527e9e..2e6f0ea79 100644
--- a/megatron/core/extensions/transformer_engine.py
+++ b/megatron/core/extensions/transformer_engine.py
@@ -4,6 +4,7 @@ import dataclasses
 import enum
