 import io
+import math
 import os
 import pickle
 import warnings
@@ -1342,6 +1343,20 @@ class TEDotProductAttention(te.pytorch.DotProductAttention):
         num_splits: Optional[int] = None,
     ) -> torch.Tensor:
         """Forward."""
+        # === GIPFEL custom kernel short-circuit ===
+        # When GIPFEL_ATTN_KERNEL is set, swap the TE attention kernel for our
+        # Triton/TileLang implementation while keeping the surrounding TE
+        # LayerNorm / sequence-parallel / fused softmax intact. This gives a
+        # clean attention-only A/B against the native TE backend.
+        _gipfel_kernel = os.environ.get("GIPFEL_ATTN_KERNEL", "").lower()
+        if _gipfel_kernel in ("triton", "tilelang"):
+            from kernels import run_attention as _gipfel_run_attention
+            _causal = (attn_mask_type == AttnMaskType.causal)
+            _scale = 1.0 / math.sqrt(query.size(-1))
+            _out = _gipfel_run_attention(query, key, value, _causal, _scale)
+            sq_, b_, np_, hn_ = _out.shape
+            return _out.reshape(sq_, b_, np_ * hn_)
+
         if packed_seq_params is not None:
